{
  "name": "Leave-management-app",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-emp-leaves": "cds watch --open empleaves/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-employees": "cds watch --open employees/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-employee": "cds watch --open employee/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/emp-leaves",
    "app/employees",
    "app/employees",
    "app/employee"
  ],
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db/my.db"
        }
      }
    }
  }
}
